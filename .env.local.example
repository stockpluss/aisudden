# Google Sheets API - Service Account (shared)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gmail API - impersonate this Workspace user (domain-wide delegation required)
GMAIL_SENDER_EMAIL=ulismoon@stockplus.im

# Stockplus
STOCKPLUS_SHEET_ID=spreadsheet-id-here
STOCKPLUS_SHEET_TAB=Sheet1
# Leave empty to skip email notification
STOCKPLUS_EMAIL_FROM=support@stockplus.im
STOCKPLUS_EMAIL_TO=ceo@stockplus.im

# Shinjeong
SHINJEONG_SHEET_ID=spreadsheet-id-here
SHINJEONG_SHEET_TAB=Sheet1
# Leave empty to skip email notification
SHINJEONG_EMAIL_FROM=
SHINJEONG_EMAIL_TO=

# Solapi - Kakao Message
SOLAPI_API_KEY=YOUR_SOLAPI_API_KEY
SOLAPI_API_SECRET_KEY=YOUR_SOLAPI_API_SECRET_KEY
# From number must be registered in solapi account.
SOLAPI_FROM_NUMBER=01012345678
KAKAO_CHANNEL_ID=KA_YOUR_KAKAO_CHANNEL_ID_AKA_PFID
KAKAO_TEMPLATE_ID=KA_YOUR_KAKAO_TEMPLATE_ID
# Leave empty to skip alimtalk for shinjeong
SHINJEONG_KAKAO_TEMPLATE_ID=
